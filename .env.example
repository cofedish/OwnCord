OWNCORD_VERSION=dev
OWNCORD_ADMIN_PORT=8080
OWNCORD_MINIO_CONSOLE_PORT=9001

# Reverse proxy profile.
# Required when running `docker compose --profile proxy up -d`.
OWNCORD_DOMAIN=chat.example.com
OWNCORD_HTTP_PORT=80
OWNCORD_HTTPS_PORT=443

# PostgreSQL
OWNCORD_DB_NAME=owncord
OWNCORD_DB_USER=owncord
OWNCORD_DB_PASSWORD=change-this-postgres-password

# Redis
OWNCORD_REDIS_PASSWORD=change-this-redis-password

# S3 / MinIO
OWNCORD_S3_REGION=us-east-1
OWNCORD_S3_BUCKET=owncord
OWNCORD_S3_ACCESS_KEY=owncord
OWNCORD_S3_SECRET_KEY=change-this-minio-secret
